# =====================================================================
# ProfessorIA — variáveis de ambiente
# =====================================================================
# COPIE este arquivo:
#   - para  frontend/.env.local   apenas as linhas marcadas [FRONTEND]
#   - para  backend/.env          apenas as linhas marcadas [BACKEND]
# Nunca commite .env / .env.local — ambos já estão nos .gitignore.
# =====================================================================


# ---------- Supabase ----------
# Pegue em: Supabase → Project Settings → API
# [FRONTEND] usa a anon key (pública, segura para o navegador)
# [BACKEND]  usa a service_role key (PRIVADA — bypassa RLS, nunca exponha)

# [FRONTEND]
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# [BACKEND]
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
# String de conexão direta ao Postgres (Supabase → Connect → URI)
# Use "Transaction pooler" para o Railway, "Direct connection" para dev local.
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres


# ---------- Anthropic (Claude API) — ÚNICO custo recorrente ----------
# Pegue em: https://console.anthropic.com/settings/keys
# [BACKEND]
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx


# ---------- Embeddings ----------
# Embeddings rodam LOCALMENTE com sentence-transformers (zero custo).
# Modelo padrão: all-MiniLM-L6-v2 (384 dims, ~80 MB, baixado na 1ª execução).
# Para trocar, defina abaixo (qualquer modelo de 384 dims compatível com
# sentence-transformers; manter dimensão pra não quebrar o pgvector).
# [BACKEND]
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ---------- MVP single-user (temporário) ----------
# Enquanto não implementamos auth Supabase no backend, todos os professores
# criados ficam vinculados a este UUID. Crie um usuário no Supabase Auth
# (Dashboard → Authentication → Users → Add user), copie o ID e cole aqui.
# [BACKEND]
MVP_USER_ID=00000000-0000-0000-0000-000000000000


# ---------- URL do backend (lida pelo frontend) ----------
# Local: http://localhost:8000
# Produção: URL pública do Railway (ex.: https://professor-ia-api.up.railway.app)
# [FRONTEND]
NEXT_PUBLIC_API_URL=http://localhost:8000
